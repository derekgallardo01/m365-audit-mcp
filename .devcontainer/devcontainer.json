{
  "name": "m365-audit-mcp",
  "build": {
    "dockerfile": "../Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "bierner.markdown-mermaid"
      ],
      "settings": {
        "python.testing.pytestEnabled": true,
        "python.testing.unittestEnabled": false
      }
    }
  },
  "postCreateCommand": "pip install -e . && pip install pytest && python -m pytest -q || true",
  "remoteUser": "root"
}
